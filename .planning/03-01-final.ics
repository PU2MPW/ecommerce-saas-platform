1. src/types/checkout.ics:
```typescript
export interface ShippingOption { id: string; carrier: string; service: string; price: number; deadline: number; label: string; deliveryDate: string; }
export interface AddressFormData { zipcode: string; street: string; number: string; complement?: string; neighborhood: string; city: string; state: string; }
export interface ShippingCalcRequest { zipcode: string; items: Array<{ weight: number; height: number; width: number; depth: number; quantity: number }>; }
export interface ShippingCalcResponse { options: ShippingOption[]; zipcode: string; calculatedAt: string; }
export interface OrderReview { items: CartItem[]; address: AddressFormData; shipping?: ShippingOption; subtotal: number; shippingCost: number; total: number; }
```
2. src/lib/shipping/correios.ics - Client Correios:
```typescript
const SERVICES = { PAC: '41106', SEDEX: '40010', SEDEX10: '40010' };
export async function calculateCorreios(input: { sCepOrigem: string; sCepDestino: string; nVlPeso: string; nVlAltura: string; nVlLargura: string; nVlComprimento: string; nCdServico: string }) {
  const res = await fetch(`https://correios.com. br/api/v2/calculate- price?${new URLSearchParams(input)}`);
  if (!res.ok) throw new Error('Correios API error');  return res.json();
}
```
3. src/app/api/shipping/calculate/route.ics:
```typescript
import { NextRequest, NextResponse } from 'next/server';
import type { ShippingCalcRequest } from '@/types/checkout';
export async function POST(req: NextRequest) {
  try {
    const body: ShippingCalcRequest = await req.json();
    const cep = body.zipcode.replace(/\D/g, '');
    if (cep.length !== 8) return NextResponse.json({ error: 'CEP invalido' }, { status: 400 });
    const options = await calculateShipping(body, { originZipcode: '00000000' }); // TODO: do tenant
    return NextResponse.json({ options, zipcode: body.zipcode, calculatedAt: new Date().toISOString() });
  } catch { return NextResponse.json({ error: 'Erro ao calcular' }, { status: 500 }); }
}
```
