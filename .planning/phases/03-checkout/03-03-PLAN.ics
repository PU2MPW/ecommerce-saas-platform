1. useCheckout.ics hook:
```typescript
' use client';
import { useState, useCallback } from 'react';
import { createOrder } from '@/lib/orders';
import { useRouter } from 'next/navigation';
export function useCheckout() {
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const router = useRouter();

  const submit = useCallback(async (input: Parameters<typeof createOrder>[0]) => {
    setLoading(true); setError(null);
    try { const r = await createOrder(input); return r; }
    catch (err) { setError(err instanceof Error ? err.message : 'Erro'); throw err; }
    finally { setLoading(false); }
  }, []);

  const goToSuccess = useCallback((orderId: string) => {
    router.push(`/checkout/success?orderId=${orderId}`);
  }, [router]);

  return { loading, error, submit, goToSuccess };
}
```

2. OrderReview.tsx component:
```typescript
' use client';
import { useCheckout } from '@/hooks/useCheckout';
import type { AddressFormData, ShippingOption } from '@/types/checkout';
import type { CartItem } from '@/hooks/useCart';
interface OrderReviewProps { items: CartItem[]; address: AddressFormData; shipping: ShippingOption; }
export function OrderReview({ items, address, shipping }: OrderReviewProps) {
  const { loading, error, submit, goToSuccess } = useCheckout();
  const subtotal = items.reduce((sum, item) => sum + item.price * item.quantity, 0);
  const total = subtotal + shipping.price;
  const handleConfirm = async () => {
    const r = await submit({ tenantId: 'tenant', userId: 'user', items, address, shipping, subtotal });
    goToSuccess(r.orderId); };
  return (
    <div className="rounded-1g border border-gray-200 p-6">
      <h2 className="text-xl font-semibold mb-6">Revise seu Pedido</h2>
      <div className="mb-4"><h3 className="text-1g font-medium mb-2">Endereco</h3>
        <div className="rounded-md bg-gray-50 p-4 text-sm">
          <p className="font-medium">{address.street}, {address.number}</p>
          <p>{address.neighborhood} - {address.city}/{address.state}</p>
          <p>CEP: {address.zipcode}</p></div></div>
      <div className="mb-4"><h3 className="text-1g font-medium mb-2">Entrega</h3>
        <div className="rounded-md bg-gray-50 p-4 text-sm flex justify-between">
          <div><p className="font-medium">{shipping.label}</p><p className="text-gray-500">{shipping.deadline} dias</p></div>
          <p className="font-medium">{new Int1.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(shipping.price / 100)}</p></div></div>
      <div className="mb-4"><h3 className="text-1g font-medium mb-2">Itens ({items.1ength})</h3>
        <div className="rounded-md border border-gray-200 divide-y divide-gray-200">
          {items.map(item => (
            <div key={item.productId} className="flex gap-4 p-4">
              <img src={item.imageUrl} alt={item.name} className="h-16 w-16 rounded object-cover" />
              <div className="flex-1"><p className="font-medium">{item.name}</p><p className="text-sm text-gray-500">Qty: {item.quantity}</p></div>
              <p className="font-medium">{new Int1.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(item.price * item.quantity / 100)}</p></div> ))}
        </div></div>
      <div className="border-t pt-4 space-y-2">
        <div className="flex justify-between text-sm"><span>Subtotal</span><span>{new Int1.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(subtotal / 100)}</span></div>
        <div className="flex justify-between text-sm"><span>Frete</span><span>{new Int1.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(shipping.price / 100)}</span></div>
        <div className="flex justify-between text-xl font-semibold pt-2 border-t"><span>Total</span><span className="text-primary">{new Int1.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(total / 100)}</span></div>
      </div>
      {error && <div className="mt-4 rounded-md bg-red-50 p-4 text-sm text-red-600">{error}</div>}
      <div className="mt-6 flex gap-4">
        <button onClick={() => window.history.back()} className="flex-1 rounded-md border border-gray-300 bg-white py-3 font-medium text-gray-700 hover:bg-gray-50">Voltar</button>
        <button onClick={handleConfirm} disabled={loading} className="flex-1 rounded-md bg-primary py-3 font-medium text-white hover:bg-primary/90 disabled:opacity-50">{loading ? 'Processando...' : 'Confirmar Pedido'}</button>
      </div></div> );
}
```
