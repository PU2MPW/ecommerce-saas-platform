1. useShipping.ics - Hook de calculo de fretes:\
```typescript\
'use client';\
import { useState, useCallback } from 'react';\
import type { ShippingOption } from '@/types/checkout';\
\
export function useShipping() {\
  const [options, setOptions] = useState<ShippingOption[]>([]);\
  const [loading, setLoading] = useState(false);\
  const [error, setError] = useState<string | null>(null);\
\
  const calculate = useCallback(async (\
    zipcode: string,\
    cartItems: Array<{ weight: number; height: number; width: number; depth: number; quantity: number }>\
  ) => {\
    if (zipcode.replace(/\D/g, '').length < 8) return;\
    setLoading(true); setError(null);\
    try {\
      const res = await fetch('/api/shipping/calculate', {\
        method: 'POST',\
        headers: { 'Content-Type': 'application/json' },\
        body: JSON.stringify({ zipcode, items: cartItems }),\
      });\
      if (!res.ok) throw new Error('Erro ao calcular');\
      const data = await res.json();\
      setOptions(data.options || []);\
    } catch (err) {\
      setError(err instanceof Error ? err.message : 'Erro');\
      setOptions([]);\
    } finally { setLoading(false); }\
  }, []);\
\
  return { options, loading, error, calculate };\
}\
```\
\
2. AddressForm.ics - Formulario com validacao de CEP:\
```typescript\
'use client';\
import { useState } from 'react';\
import type { AddressFormData } from '@/types/checkout';\
\
interface AddressFormProps {\
  onSubmit: (address: AddressFormData) => void;\
  onValidChange: (isValid: boolean) => void;\
}\
\
function validate(data: Partial<AddressFormData>) {\
  return /^\d{5}-?\d{3}$/.test(data.zipcode || '') &&\
    (data.street?.length || 0) > 0 &&\
    (data.number?.length || 0) > 0 &&\
    (data.neighborhood?.length || 0) > 0 &&\
    (data.city?.length || 0) > 0 &&\
    (data.state?.length || 0) === 2;\
}\
\
export function AddressForm({ onSubmit, onValidChange }: AddressFormProps) {\
  const [data, setData] = useState<AddressFormData>({\
    zipcode: '', street: '', number: '', complement: '', neighborhood: '', city: '', state: ''\
  });\
\
  const [errors, setErrors] = useState<Partial<Record<keyof AddressFormData, string>>({});\
\
  const lookupCEP = async (cep: string) => {\
    const clean = cep.replace(/\D/g, '');\
    if (clean.length !== 8) return;\
    try {\
      const res = await fetch(`/api/cep/${clean}`);\
      if (res.ok) {\
        const d = await res.json();\
        setData(prev => ({ ...prev,\
          street: d.logradouro || '',\
          neighborhood: d.bairro || '',\
          city: d.localidade || '',\
          state: d.uf || ''\
        }));\
      }\
    } catch {}\
  };\
\
  return (\
    <form className="space-y-4">\
      <div>\
        <label className="block text-sm font-medium text-gray-700">CEP</label>\
        <input\
          type="text"\
          value={data.zipcode}\
          onChange={e => setData(p => ({ ...p, zipcode: e.target.value }))}\
          onBlur={e => lookupCEP(e.target.value)}\
          placeholder="00.000-000"\
          className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 focus:border-primary focus:ring-primary" />\
      </div>\
      <div>\
        <label className="block text-sm font-medium text-gray-700">Endereco</label>\
        <input\
          type="text"\
          value={data.street}\
          onChange={e => setData(p => ({ ...p, street: e.target.value }))}\
          className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />\
      </div>\
      <div className="grid grid-cols-2 gap-4">\
        <div>\
          <label className="block text-sm font-medium text-gray-700">Numero *</label>\
          <input\
            type="text"\
            value={data.number}\
            onChange={e => setData(p => ({ ...p, number: e.target.value }))}\
            className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />\
        </div>\
        <div>\
          <label className="block text-sm font-medium text-gray-700">Complemento</label>\
          <input\
            type="text"\
            value={data.complement}\
            onChange={e => setData(p => ({ ...p, complement: e.target.value }))}\
            className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />\
        </div>\
      </div>\
      <div>\
        <label className="block text-sm font-medium text-gray-700">Bairro</label>\
        <input\
          type="text"\
          value={data.neighborhood}\
          onChange={e => setData(p => ({ ...p, neighborhood: e.target.value }))}\
          className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />\
      </div>\
      <div className="grid grid-cols-2 gap-4">\
        <div>\
          <label className="block text-sm font-medium text-gray-700">Cidade</label>\
          <input\
            type="text"\
            value={data.city}\
            onChange={e => setData(p => ({ ...p, city: e.target.value }))}\
            className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />\
        </div>\
        <div>\
          <label className="block text-sm font-medium text-gray-700">UF</label>\
          <select\
            value={data.state}\
            onChange={e => setData(p => ({ ...p, state: e.target.value }))}\
            className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2">\
            <option value="">Selecione</option>\
            <option value="SP">SP</option> <option value="RJ">RJ</option> <option value="MG">MG</option>\
            <option value="RS">RS</option> <option value="PR">PR</option> <option value="SC">SC</option>\
            <option value="BA">BA</option> <option value="PE">PE</option> <option value="CE">CE</option>\
            <option value="GO">GO</option> <option value="DF">DF</option>\
          </select>\
        </div>\
      </div>\
    </form>\
  );\
}\
```\
