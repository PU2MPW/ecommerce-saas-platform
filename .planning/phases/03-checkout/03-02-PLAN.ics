ShippingOptions.ics - Componente de selecao de entrega:\
```typescript\
'use client';\
import { useShipping } from '@/hooks/useShipping';\
import type { ShippingOption } from '@/types/checkout';\
\
interface ShippingOptionsProps {\
  zipcode: string;\
  cartItems: Array<{ weight: number; height: number; width: number; depth: number; quantity: number }>;\
  selectedId?: string;\
  onSelect: (option: ShippingOption) => void;\
}\
\
export function ShippingOptions({ zipcode, cartItems, selectedId, onSelect }: ShippingOptionsProps) {\
  const { options, loading, error, calculate } = useShipping();\
\
\
  useEffect(() => {\
    if (zipcode.length >= 8) calculate(zipcode, cartItems);\
  }, [zipcode, cartItems.length, calculate]);\
\
  if (loading) {\
    return (\
      <div className="flex items-center justify-center py-8">\
        <div className="h-6 w-6 animate-spin rounded-full border-2 border-primary border-t-transparent" />\
        <span className="ml-2 text-sm text-gray-500">Calculando fretes...</span>\
      </div>\
    );\
  }\
\
  if (error) {\
    return <div className="rounded-md bg-red-50 p-4 text-sm text-red-600">{error}</div>;\
  }\
\
  if (options.length === 0) {\
    return <div className="text-sm text-gray-500">Insira um CEP valido para ver as opcoes.</div>;\
  }\
\
  return (\
    <div className="space-y-2">\
      {options.map(opt => (\
        <label\
          key={opt.id}\
          className={`flex items-center justify-between p-4 rounded-lg border cursor-pointer transition-colors ${\
            selectedId === opt.id ? 'border-primary bg-primary/5' : 'border-gray-200 hover:border-gray-300'\
          }`}\
        >\
          <div className="flex items-center gap-3">\
            <input\
              type="radio"\
              name="shipping"\
              checked={selectedId === opt.id}\
              onChange={() => onSelect(opt)}\
              className="h-4 w-4" />\
            <div>\
              <p className="font-medium">{opt.label}</p>\
              <p className="text-sm text-gray-500">Entrega em {opt.deadline} dias uteis</p>\
            </div>\
          </div>\
          <p className="font-semibold">\
            {new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(opt.price / 100)}\
          </p>\
        </label>\
      ))}\
    </div>\
  );\
}\
```\
